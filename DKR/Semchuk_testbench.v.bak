`timescale 1ns / 1ps

module Semchuk_testbench;

reg [3:0] R, S;
reg CI;
reg [2:0] H;
reg [1:0] I;

wire [3:0] Y, Y_norm;
wire CO, VO, NO, ZO;

ALB uut (
    .R(R),
    .S(S),
    .CI(CI),
    .H(H),
    .I(I),
    .Y(Y),
    .Y_norm(Y_norm),
    .CO(CO),
    .VO(VO),
    .NO(NO),
    .ZO(ZO)
);

initial begin

    $display("=== ALB Test Variant 011 ===");

    H = 3'b011;

    // SUB
    R = 4'b1000;
    S = 4'b0100;
    CI = 1'b1;
    I = 2'b00;

    #10;

    $display("[00] SUB R=%b S=%b CI=%b => Y=%b Y_norm=%b | CO=%b VO=%b NO=%b ZO=%b",
              R, S, CI, Y, Y_norm, CO, VO, NO, ZO);


    // AND
    R = 4'b1101;
    S = 4'b0111;
    CI = 1'b0;
    I = 2'b01;

    #10;

    $display("[01] AND R=%b S=%b CI=%b => Y=%b Y_norm=%b | CO=%b VO=%b NO=%b ZO=%b",
              R, S, CI, Y, Y_norm, CO, VO, NO, ZO);


    // ADD
    R = 4'b0101;
    S = 4'b0011;
    CI = 1'b1;
    I = 2'b10;

    #10;

    $display("[10] ADD R=%b S=%b CI=%b => Y=%b Y_norm=%b | CO=%b VO=%b NO=%b ZO=%b",
              R, S, CI, Y, Y_norm, CO, VO, NO, ZO);


    // OR
    R = 4'b0101;
    S = 4'b1000;
    CI = 1'b0;
    I = 2'b11;

    #10;

    $display("[11] OR R=%b S=%b CI=%b => Y=%b Y_norm=%b | CO=%b VO=%b NO=%b ZO=%b",
              R, S, CI, Y, Y_norm, CO, VO, NO, ZO);


    // ZERO
    R = 4'b0101;
    S = 4'b0101;
    CI = 1'b1;
    I = 2'b00;

    #10;

    $display("[00] ZERO R=%b S=%b CI=%b => Y=%b Y_norm=%b | CO=%b VO=%b NO=%b ZO=%b",
              R, S, CI, Y, Y_norm, CO, VO, NO, ZO);


    // OVERFLOW ADD
    R = 4'b0111;
    S = 4'b0001;
    CI = 1'b0;
    I = 2'b10;

    #10;

    $display("[10] OVERFLOW ADD R=%b S=%b CI=%b => Y=%b Y_norm=%b | CO=%b VO=%b NO=%b ZO=%b",
              R, S, CI, Y, Y_norm, CO, VO, NO, ZO);


    // CARRY ADD
    R = 4'b1111;
    S = 4'b0001;
    CI = 1'b0;
    I = 2'b10;

    #10;

    $display("[10] CARRY ADD R=%b S=%b CI=%b => Y=%b Y_norm=%b | CO=%b VO=%b NO=%b ZO=%b",
              R, S, CI, Y, Y_norm, CO, VO, NO, ZO);


    $stop;

end

endmodule
